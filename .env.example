# ── App mode ────────────────────────────────────────────────────────────────
# What "the normal site" is. One Vercel project, one Neo4j graph. The /demo
# path is ALWAYS the read-only showcase regardless of this value. See
# docs/MODES.md.
#
#   collect — data-collection build: signup → voice → interests → done. Writes
#             real users into the graph. Send friends the root URL; share /demo
#             for the read-only showcase. (Recommended for the live project.)
#   full    — complete hackathon demo flow (default if unset).
#
# Local tip: append ?mode=collect|full to any URL to flip the client without
# rebuilding. Visit /demo for the showcase.
NEXT_PUBLIC_APP_MODE=collect

# ── AI pipeline ──────────────────────────────────────────────────────────────
# Required for live voice transcription (ElevenLabs Scribe).
ELEVENLABS_API_KEY=
# Required for topic/activity analysis (Ollama Cloud). Keyword fallback runs
# client-side if this is missing.
OLLAMA_API_KEY=
# Optional — defaults to https://ollama.com/v1
LLM_BASE_URL=
# Optional — Ollama Cloud model ids (see https://ollama.com/api/tags)
# Understand pass (topics): accuracy-critical — default gpt-oss:120b
LLM_MODEL_UNDERSTAND=gpt-oss:120b
# Suggest pass (activities): latency-sensitive — default deepseek-v4-flash
LLM_MODEL_SUGGEST=deepseek-v4-flash
# Fallback if the above are unset
# LLM_MODEL=gpt-oss:120b

# ── Firebase (passwordless email link + Google sign-in) ─────────────────────
# All NEXT_PUBLIC_FIREBASE_* from Firebase Console → Project settings → Your apps.
# Also required in Firebase Console → Authentication:
#   • Get started (enable Auth product)
#   • Sign-in method → Email/Password ON
#   • Sign-in method → Email link (passwordless) ON
#   • Settings → Authorized domains → add localhost, your Vercel prod domain,
#     and any preview domain you test on
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Neo4j (graph + matching) ─────────────────────────────────────────────────
# All three builds talk to the SAME database so collect fills it and demo reads
# it. Point every deployment at one AuraDB instance.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
# Optional — defaults to "neo4j"
NEO4J_DATABASE=
