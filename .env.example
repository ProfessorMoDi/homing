# ── App mode ────────────────────────────────────────────────────────────────
# What "the normal site" is. One Vercel project, one Neo4j graph. The /demo
# path is ALWAYS the read-only showcase regardless of this value. See
# docs/MODES.md.
#
#   collect — data-collection build: signup → voice → interests → done. Writes
#             real users into the graph. Send friends the root URL; share /demo
#             for the read-only showcase. (Recommended for the live project.)
#   full    — complete hackathon demo flow (default if unset).
#
# Local tip: append ?mode=collect|full to any URL to flip the client without
# rebuilding. Visit /demo for the showcase.
NEXT_PUBLIC_APP_MODE=collect

# ── AI pipeline ──────────────────────────────────────────────────────────────
# Required for live voice transcription (ElevenLabs Scribe).
ELEVENLABS_API_KEY=
# Required for topic/activity analysis (Ollama Cloud). Keyword fallback runs
# client-side if this is missing.
OLLAMA_API_KEY=
# Optional — defaults to https://ollama.com/v1
LLM_BASE_URL=

# ── Neo4j (graph + matching) ─────────────────────────────────────────────────
# All three builds talk to the SAME database so collect fills it and demo reads
# it. Point every deployment at one AuraDB instance.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
# Optional — defaults to "neo4j"
NEO4J_DATABASE=
