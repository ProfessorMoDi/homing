# ── App mode ────────────────────────────────────────────────────────────────
# Which build this deployment is. One codebase, three products, one shared
# Neo4j graph. See docs/MODES.md.
#
#   full    — complete demo flow (default if unset)
#   collect — data-collection build: signup → voice → interests → done.
#             Writes real users into the graph. This is the link you send to
#             friends to fill the network.
#   demo    — read-only "find your people" build. Reads the network the collect
#             build filled and ranks matches. Writes nothing.
#
# Local tip: append ?mode=collect|demo|full to any URL to flip the client
# without rebuilding.
NEXT_PUBLIC_APP_MODE=full

# ── AI pipeline ──────────────────────────────────────────────────────────────
# Required for live voice transcription (ElevenLabs Scribe).
ELEVENLABS_API_KEY=
# Required for topic/activity analysis (Ollama Cloud). Keyword fallback runs
# client-side if this is missing.
OLLAMA_API_KEY=
# Optional — defaults to https://ollama.com/v1
LLM_BASE_URL=

# ── Neo4j (graph + matching) ─────────────────────────────────────────────────
# All three builds talk to the SAME database so collect fills it and demo reads
# it. Point every deployment at one AuraDB instance.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
# Optional — defaults to "neo4j"
NEO4J_DATABASE=
